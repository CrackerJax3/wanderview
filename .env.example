# WanderView API Keys
# Copy this file to .env.local and fill in your keys

# Mistral AI — for narration, chat, and mission generation
# Get your key at https://console.mistral.ai/
VITE_MISTRAL_API_KEY=

# Google Maps — for 3D Tiles and Places API
# Get your key at https://console.cloud.google.com/
# Enable: Map Tiles API, Places API (New)
VITE_GOOGLE_API_KEY=
